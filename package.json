{
  "name": "dancetempo",
  "description": "DanceTech Protocol — reference superapp on Tempo + MPP (battle, coaching, beats, dance-extras, integrations)",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server/index.js",
    "dev:full": "concurrently \"npm run server\" \"npm run dev\"",
    "build:llm": "node scripts/build-llm-full.mjs",
    "evvm:vendor": "node scripts/install-evvm.mjs",
    "build": "npm run build:llm && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@x402/extensions": "^2.7.0",
    "buffer": "^6.0.3",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mppx": "^0.4.7",
    "multer": "^2.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
