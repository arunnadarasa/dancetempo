# Optional: cap for mppx session-channel auto-deposit (USD-style TIP-20 units). Default 50 if unset.
# VITE_TEMPO_MPP_MAX_DEPOSIT=50

OPENAI_API_KEY=
# Hub explainer + optional Bearer for MPP proxy. Wallet-only: leave empty and use /openai + Tempo mainnet.
OPENAI_MODEL=gpt-4o-mini
# OpenAI-compatible gateway on Tempo MPP (chat completions).
OPENAI_MPP_BASE_URL=https://openai.mpp.tempo.xyz
# Anthropic (Claude) on Tempo MPP — see /anthropic. Optional key skips wallet; API overview: https://platform.claude.com/docs/en/api/overview
ANTHROPIC_API_KEY=
ANTHROPIC_MPP_BASE_URL=https://anthropic.mpp.tempo.xyz
# Optional; default matches Anthropic Messages API.
# ANTHROPIC_API_VERSION=2023-06-01
# OpenRouter on Tempo MPP — see /openrouter. Docs index: https://openrouter.ai/docs/llms.txt
OPENROUTER_API_KEY=
OPENROUTER_MPP_BASE_URL=https://openrouter.mpp.tempo.xyz
# Perplexity (Sonar / Search / Embeddings) on Tempo MPP — see /perplexity. Docs index: https://docs.perplexity.ai/llms-full.txt
PERPLEXITY_API_KEY=
PERPLEXITY_MPP_BASE_URL=https://perplexity.mpp.tempo.xyz
# Alchemy (RPC + NFT API v3) on MPP — see /alchemy. Docs index: https://www.alchemy.com/llms.txt
ALCHEMY_API_KEY=
ALCHEMY_MPP_BASE_URL=https://mpp.alchemy.com
# fal.ai (image / video / audio models) on Tempo MPP — see /fal. Docs index: https://fal.ai/docs/llms.txt
FAL_API_KEY=
FAL_MPP_BASE_URL=https://fal.mpp.tempo.xyz
# Replicate (models / predictions) on MPP — see /replicate. Docs index: https://replicate.com/docs/llms.txt
REPLICATE_API_KEY=
REPLICATE_MPP_BASE_URL=https://replicate.mpp.paywithlocus.com
# Parallel MPP gateway (search / extract / task). Wallet-paid via app proxy; see /parallel
PARALLEL_BASE_URL=https://parallelmpp.dev
# Legacy: not used by DanceTempo proxy (use Tempo mainnet + mppx instead).
PARALLEL_API_KEY=
# Optional Bearer for direct AgentMail API calls (see server routes). Catalog: https://mpp.dev/services#agentmail
AGENTMAIL_API_KEY=your_agentmail_api_key_here
# Direct REST API (v0 inboxes, messages, …) — not the MPP gateway host.
AGENTMAIL_BASE_URL=https://api.agentmail.to
# Wallet-paid MPP gateway — must match the AgentMail entry on the MPP catalog (default below).
AGENTMAIL_MPP_BASE_URL=https://mpp.api.agentmail.to
# Fallback if the client omits `inbox_id` (the /dance-extras bot flow sends `streetkode@agentmail.to` by default).
AGENTMAIL_INBOX_ID=your_agentmail_inbox_id_here
# Legacy (no longer used by the server): AgentMail send is now
# POST /v0/inboxes/{inbox_id}/messages/send
AGENTMAIL_SEND_PATH=/v1/send
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
AVIATIONSTACK_BASE_URL=http://api.aviationstack.com/v1
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
GOOGLE_MAPS_BASE_URL=https://maps.googleapis.com/maps/api
KICKSDB_API_KEY=your_kicksdb_api_key_here
KICKSDB_BASE_URL=https://kicksdb.mpp.tempo.xyz
KICKSDB_SEARCH_PATH=/v3/stockx/products
# Optional: OpenWeather `appid` for direct queries. If unset, use /weather + wallet MPP on Tempo mainnet.
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://weather.mpp.paywithlocus.com
# MPP gateway uses POST JSON (see mpp.dev OpenWeather). Not legacy GET /data/2.5/weather.
OPENWEATHER_CURRENT_PATH=/openweather/current-weather
# Suno MPP host (optional overrides; Music uses wallet-paid x402 / MPP on Tempo mainnet).
SUNO_BASE_URL=https://suno.mpp.paywithlocus.com
SUNO_GENERATE_PATH=/suno/generate-music
# Optional legacy header auth; StablePhone primarily uses x402 + SIWX flows.
STABLEPHONE_API_KEY=
STABLEPHONE_BASE_URL=https://stablephone.dev
STABLEPHONE_CALL_PATH=/api/call
STABLEPHONE_STATUS_PATH=/api/call
STABLESOCIAL_BASE_URL=https://stablesocial.dev
STABLESOCIAL_INSTAGRAM_PROFILE_PATH=/api/instagram/profile
STABLESOCIAL_JOBS_PATH=/api/jobs
CARD_PROVIDER=laso
LASO_BASE_URL=https://laso.mpp.paywithlocus.com
LASO_MPP_PATH=/get-card
LASO_CARD_STATUS_PATH=/get-card-data
PORT=8787

# Tempo: testnet (42431, pathUSD) or mainnet (4217, USDC)
TMPO_TESTNET=true

# Payment scaffold (used when PAYMENT_MODE=mock or live)
PAYMENT_MODE=mock
MPP_CURRENCY=
MPP_RECIPIENT=0x742d35Cc6634c0532925a3b844bC9e7595F8fE00
MPP_DECIMALS=6
